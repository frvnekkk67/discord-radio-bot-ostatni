# Skopiuj ten plik do ".env" i uzupełnij wartości (lokalnie).
# Na Railway te same nazwy wpisujesz w zakładce "Variables".

DISCORD_TOKEN=wstaw_token_bota_discord

# Lavalink - dane serwera muzycznego (osobna usługa, patrz README.md sekcja "Lavalink").
# Jeśli obie usługi (bot i Lavalink) są w TYM SAMYM projekcie Railway, użyj
# prywatnej domeny Railway, np. LAVALINK_HOST=lavalink.railway.internal
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Dashboard - token dostępu do panelu webowego. USTAW WŁASNY, LOSOWY CIĄG.
DASHBOARD_TOKEN=zmien-to-na-wlasny-losowy-token

# Opcjonalne:
# DB_PATH=/data/radio.db
# PORT=8080
# DEFAULT_VOLUME=70
